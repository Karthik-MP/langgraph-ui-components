{
  "name": "langgraph-ui-components",
  "private": false,
  "version": "0.0.31",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Karthik-MP/langgraph-ui-components.git"
  },
  "homepage": "https://github.com/Karthik-MP/langgraph-ui-components#readme",
  "bugs": {
    "url": "https://github.com/Karthik-MP/langgraph-ui-components/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    },
    "./providers": {
      "types": "./dist/entries/providers.d.ts",
      "import": "./dist/entries/providers.es.js",
      "require": "./dist/entries/providers.cjs.js"
    },
    "./components": {
      "types": "./dist/entries/components.d.ts",
      "import": "./dist/entries/components.es.js",
      "require": "./dist/entries/components.cjs.js"
    },
    "./hooks": {
      "types": "./dist/entries/hooks.d.ts",
      "import": "./dist/entries/hooks.es.js",
      "require": "./dist/entries/hooks.cjs.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "typesVersions": {
    "*": {
      "providers": [
        "./dist/entries/providers.d.ts"
      ],
      "components": [
        "./dist/entries/components.d.ts"
      ],
      "hooks": [
        "./dist/entries/hooks.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build:css": "cp dist/assets/*.css dist/styles.css 2>/dev/null || true",
    "build:js": "vite build",
    "build": "pnpm run build:js && pnpm run build:css",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepublishOnly": "pnpm run build",
    "type-check": "tsc -p tsconfig.app.json --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "katex": "^0.16.28",
    "react-syntax-highlighter": "^16.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.2.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0"
  },
  "peerDependencies": {
    "@langchain/core": "^1.1.33",
    "@langchain/langgraph": "^1.2.3",
    "@langchain/langgraph-sdk": "^1.7.4",
    "framer-motion": "^12.23.26",
    "lucide-react": "^0.562.0",
    "openai": "^6.15.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-spinners": "^0.17.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@langchain/core": "^1.1.33",
    "@langchain/langgraph": "^1.2.3",
    "@langchain/langgraph-sdk": "^1.7.4",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "framer-motion": "^12.23.26",
    "globals": "^16.5.0",
    "lucide-react": "^0.562.0",
    "openai": "^6.15.0",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-spinners": "^0.17.0",
    "sonner": "^2.0.7",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4"
  },
  "keywords": [
    "langgraph",
    "langgraph-ui",
    "react",
    "chat-ui",
    "ai-components",
    "chatbot",
    "sidebar",
    "streaming",
    "langchain",
    "assistant",
    "chatgpt-ui",
    "human-in-the-loop",
    "hitl",
    "generative-ui"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
